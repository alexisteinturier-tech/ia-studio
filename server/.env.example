# ── Copier ce fichier en « .env » et remplir avec votre clé API Resend ──
# Resend (resend.com) : Dashboard → API Keys → Create API Key

RESEND_API_KEY=re_votre_cle_api
MAIL_FROM="ia studio <bonjour@ia-studio.fr>"

# Destinataire des messages du formulaire
CONTACT_TO=bonjour@ia-studio.fr

# Port du serveur (optionnel)
PORT=3000
