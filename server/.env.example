# ── Copier ce fichier en « .env » et remplir avec vos accès SMTP ──
# Exemples : OVH (ssl0.ovh.net), Gmail (smtp.gmail.com + mot de passe d'application),
# Brevo (smtp-relay.brevo.com), Ionos (smtp.ionos.fr)…

SMTP_HOST=ssl0.ovh.net
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=bonjour@ia-studio.fr
SMTP_PASS=motdepasse
SMTP_FROM="ia studio <bonjour@ia-studio.fr>"

# Destinataire des messages du formulaire
CONTACT_TO=bonjour@ia-studio.fr

# Port du serveur (optionnel)
PORT=3000
